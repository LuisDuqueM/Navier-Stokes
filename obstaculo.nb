Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"1.", " ", "Importar", " ", "los", " ", "datos"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"SetDirectory", "[", 
     RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"datosCrudos", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"\"\<resultado_fluido.csv\>\"", ",", "\"\<CSV\>\""}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"datosSinEncabezado", "=", 
     RowBox[{"Rest", "[", "datosCrudos", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"2.", " ", "Formatear", " ", "para", " ", "ListStreamPlot"}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"datosFormateados", "=", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"#", "[", 
             RowBox[{"[", "1", "]"}], "]"}], ",", 
            RowBox[{"#", "[", 
