             RowBox[{"[", "4", "]"}], "]"}]}], "}"}]}], "}"}], "&"}], ",", 
       "datosSinEncabezado"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Definir", " ", "las", " ", "coordenadas", " ", "del", " ", 
     "obst\[AAcute]culo", " ", "en", " ", "metros"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"xMin", "=", "0.33"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"xMax", "=", "0.495"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"yMin", "=", "0.33"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"yMax", "=", "0.495"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "4.", " ", "Generar", " ", "la", " ", "gr\[AAcute]fica", " ", "con", " ", 
     "el", " ", "bloque", " ", "superpuesto"}], "*)"}], "\n", 
   RowBox[{"graficaObstaculo", "=", 
    RowBox[{"ListStreamPlot", "[", 
     RowBox[{"datosFormateados", ",", 
      RowBox[{"StreamColorFunction", "->", "\"\<TemperatureMap\>\""}], ",", 
