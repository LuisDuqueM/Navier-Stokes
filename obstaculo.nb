          RowBox[{"\"\<Coordenada Y (m)\>\"", ",", "Black", ",", "14", ",", 
           "Bold"}], "]"}]}], "}"}]}], ",", 
      RowBox[{"PlotLabel", "->", 
       RowBox[{"Style", "[", 
        RowBox[{"\"\<Simulaci\[OAcute]n Navier-Stokes: Impacto con Obst\
